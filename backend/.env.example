# .env.example - Copy this file to .env and fill in your values.
# Do NOT commit the real .env file to version control.

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/pokemon_go_db

# Secret key for signing JWT tokens.
# Generate a strong random key with: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret-key

# JWT token lifetime in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60
